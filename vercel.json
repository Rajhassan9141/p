{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/backend",
      "framework": "fastapi",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "/backend"
    }
  },
  "env": {
    "NEXT_PUBLIC_API_URL": "/backend"
  }
}
